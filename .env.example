# cf-proxy configuration — copy to .env, then run: npm start
# (npm start uses `node --env-file=.env`, so these are loaded automatically)

# Server
CF_PROXY_HOST=0.0.0.0
CF_PROXY_PORT=8750

# Auth (empty = no auth required). When set, the dashboard prompts for this key.
CF_PROXY_API_KEY=

# 9router DB path (source for the manual import button)
CF_PROXY_9ROUTER_DB=/home/ubuntu/.9router/db/data.sqlite

# Own DB path (accounts + neuron counters stored here)
CF_PROXY_DB=./data/accounts.db

# Cooldown after a per-minute rate-limit 429 (seconds). NOTE: this only applies
# to rate-limit 429s. A daily-neuron-limit 429 (CF error code 4006) always cools
# the account until 00:00 UTC regardless of this value.
CF_PROXY_COOLDOWN_429=90

# Max retry attempts per request (different accounts)
CF_PROXY_MAX_RETRIES=5

# Log level: DEBUG | INFO | WARN | ERROR
CF_PROXY_LOG_LEVEL=INFO
